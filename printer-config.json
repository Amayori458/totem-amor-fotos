{
  "printer": {
    "model": "ASK300",
    "driver": "ask300-driver",
    "usb": {
      "vendorId": "0x4CB",
      "productId": "0x5006",
      "infFile": "fpusbdrv.inf",
      "sysFile": "fpusbdrv.sys"
    },
    "settings": {
      "paperSize": "10x15",
      "quality": "high",
